{
  "name": "myrdpapp-backend",
  "version": "1.0.0",
  "description": "Production-ready Windows Web RDP Platform Backend",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "NODE_ENV=development node --watch server.js",
    "db:init": "node src/database/init.js",
    "db:migrate": "node src/database/migrate.js",
    "test:module1": "node tests/config.test.js && node tests/helpers.test.js && node tests/errors.test.js",
    "test": "npm run test:module1",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "keywords": ["rdp", "remote-desktop", "windows", "websocket"],
  "author": "jayd33p",
  "license": "Proprietary",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.15.0",
    "dotenv": "^16.3.1",
    "sqlite3": "^5.1.6",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "jsonwebtoken": "^9.1.2",
    "bcryptjs": "^2.4.3",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "body-parser": "^1.20.2",
    "windows-user": "^2.0.0",
    "ldapjs": "^3.0.7",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1"
  },
  "devDependencies": {
    "eslint": "^8.54.0",
    "prettier": "^3.1.1"
  }
}
