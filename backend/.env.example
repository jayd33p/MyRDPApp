# Server Configuration
NODE_ENV=production
PORT=8443
HOST=0.0.0.0
HTTPS=true
SSL_KEY_PATH=./certs/key.pem
SSL_CERT_PATH=./certs/cert.pem
SSL_CA_PATH=./certs/ca.pem

# Database Configuration
DB_TYPE=sqlite
DB_PATH=./data/app.db
# For PostgreSQL:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=myrdpapp
# DB_USER=postgres
# DB_PASSWORD=

# RDP Configuration
RDP_HOST=localhost
RDP_PORT=3389
RDP_ENABLE_AUDIO=false
RDP_ENABLE_CLIPBOARD=true
RDP_ENABLE_FILE_TRANSFER=false
RDP_FRAME_RATE=30
RDP_QUALITY=90

# Authentication
AUTH_TYPE=windows
# AUTH_TYPE options: windows, ldap, active-directory
LDAP_SERVER=ldap://localhost:389
LDAP_BASE_DN=dc=company,dc=local
LDAP_BIND_DN=cn=admin,dc=company,dc=local
LDAP_BIND_PASSWORD=

# Session Management
SESSION_TIMEOUT=3600000
IDLE_TIMEOUT=1800000
SESSION_CHECK_INTERVAL=60000
MAX_SESSIONS_PER_USER=3

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=24h
CSRF_PROTECTION=true
ALLOWED_ORIGINS=https://localhost:8443,https://myrdpapp.example.com

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT=5
LOGIN_RATE_LIMIT_WINDOW=900000

# RDPWrap
RDPWRAP_ENABLED=true
RDPWRAP_MAX_SESSIONS=10
RDPWRAP_VALIDATION_INTERVAL=300000

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
AUDIT_LOG_FILE=./logs/audit.log

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# WebSocket
WS_PING_INTERVAL=30000
WS_PING_TIMEOUT=5000
WS_MAX_PAYLOAD_SIZE=10485760

# Optional Features
ENABLE_SESSION_RECORDING=false
ENABLE_MFA=false
ENABLE_2FA=false
ENABLE_GATEWAY_MODE=false
